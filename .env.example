# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@ep-xxxx.us-east-2.aws.neon.tech/dermaassist_db?sslmode=require

# JWT
JWT_ACCESS_TOKEN_LIFETIME=60  # minutes
JWT_REFRESH_TOKEN_LIFETIME=7  # days

# Email (console for dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Frontend URL
FRONTEND_URL=http://localhost:3000

# AI Models Path
AI_MODELS_PATH=../stitch_dermaassist_ai_healthcare_platform/stitch_dermaassist_ai_healthcare_platform/models
